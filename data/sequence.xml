<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_treasury_payment_schedule" model="ir.sequence">
        <field name="name">Treasury Payment Schedule</field>
        <field name="code">rfh.treasury.payment.schedule</field>
        <field name="prefix">TPS/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_treasury_payment_batch" model="ir.sequence">
        <field name="name">Treasury Payment Batch</field>
        <field name="code">rfh.treasury.payment.batch</field>
        <field name="prefix">TPB/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
